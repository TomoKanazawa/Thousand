# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python
__pycache__/
*.py[cod]
.venv/
venv/
.ruff_cache/
.pytest_cache/

# ml data + prototype outputs (regenerable, sometimes DUA-protected)
/data/
ml/prototype_a/cases/
ml/prototype_a/prepared/
ml/prototype_a/results.md
ml/**/__pycache__/

# MIMIC-IV raw data + derived case files — DUA-protected, never commit
/physionet.org/
ml/prototype_b/data/
ml/prototype_b/data_aki/
ml/prototype_b/selected_admissions.json
ml/prototype_b/selected_admissions_aki.json
ml/prototype_b/kdigo_aki_candidates.json
# Per-case results contain real MIMIC ICD codes/titles — keep ignored
ml/prototype_b/results_*.json
ml/prototype_b/results_*.md
ml/prototype_b/investigate_report.md
# Aggregate-only artifacts ARE commitable (no PHI / no per-case dx)
!ml/prototype_b/results_summary.md
!ml/prototype_b/kdigo_aki_report.md
!ml/prototype_b/team_report.pdf
